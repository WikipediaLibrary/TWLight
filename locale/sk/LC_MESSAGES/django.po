#: TWLight/users/templates/users/editor_detail_data.html:105
#: TWLight/users/templates/users/editor_detail_data.html:123
#: TWLight/users/templates/users/editor_detail_data.html:164
#: TWLight/users/templates/users/editor_detail_data.html:182
msgid "Unknown (requires user login)"
msgstr "Neznáme (vyžaduje prihlásenie používateľa)"

#. Translators: When viewing a user's profile (e.g. https://wikipedialibrary.wmflabs.org/users/ when logged in), this is the heading for a Yes/No ToU question.
#: TWLight/users/templates/users/editor_detail_data.html:100
msgid "Satisfies minimum edit count?"
msgstr "Spĺňa minimálny počet úprav?"

#. Translators: When viewing a user's profile (e.g. https://wikipedialibrary.wmflabs.org/users/ when logged in), this is the heading for a Yes/No ToU question.
#: TWLight/users/templates/users/editor_detail_data.html:118
msgid "Is not blocked on any project?"
msgstr "Nie je zablokovaný v žiadnom projekte?"

#. Translators: If a user has received an exemption against a criterion, this is shown next to "No" on their user page and applications next to this criterion.
#: TWLight/users/templates/users/editor_detail_data.html:132
msgid "(exemption granted)"
msgstr "(udelená výnimka)"

#. Translators: This message is shown on a user's profile if their Wikimedia account is blocked on one or more projects. They may still be granted access to the Library Bundle, but need to contact Wikipedia Library staff to verify.
#: TWLight/users/templates/users/editor_detail_data.html:137
#, python-format
msgid "It looks like you have an active block on your account. If you meet the other criteria you may still be permitted access to the library - please <a class=\"twl-links\" href=\"%(contact_url)s\">contact us</a>."
msgstr "Zdá sa, že na vašom účte máte aktívne blokovanie. Ak spĺňate ostatné kritériá, prístup do knižnice vám môže byť aj tak povolený – <a class=\"twl-links\" href=\"%(contact_url)s\">kontaktujte nás</a>."

#. Translators: When viewing a user's profile (e.g. https://wikipedialibrary.wmflabs.org/users/ when logged in), this is the heading for a Yes/No program eligibility question.
#: TWLight/users/templates/users/editor_detail_data.html:153
msgid "Eligible for Bundle?"
msgstr "Oprávnený na balík?"

#. Translators: When viewing a user's profile (e.g. https://wikipedialibrary.wmflabs.org/users/ when logged in), this question has a Yes or No answer.
#: TWLight/users/templates/users/editor_detail_data.html:156
msgid "At their last login, did this user meet the criteria set forth in the Library Bundle? Note that satisfying terms of use is a prerequisite to bundle eligibility."
msgstr "Spĺňal tento používateľ pri poslednom prihlásení kritériá uvedené pre balík knižnice? Upozorňujeme, že splnenie podmienok používania je predpokladom oprávnenosti na balík."

#. Translators: When viewing a user's profile (e.g. https://wikipedialibrary.wmflabs.org/users/ when logged in), this is the heading for a Yes/No program eligibility question.
#: TWLight/users/templates/users/editor_detail_data.html:177
msgid "Satisfies recent edit count?"
msgstr "Spĺňa počet nedávnych úprav?"

#. Translators: When viewing a user's profile (e.g. https://wikipedialibrary.wmflabs.org/users/ when logged in), this labels the edit current count of the user across all Wikimedia projects. Don't remove the *
#: TWLight/users/templates/users/editor_detail_data.html:198
msgid "Current global edit count *"
msgstr "Aktuálny globálny počet úprav *"

#. Translators: this links to a Tools page with edit stats for a given wikipedia editor.
#: TWLight/users/templates/users/editor_detail_data.html:205
msgid "(view global user contributions)"
msgstr "(zobraziť globálne príspevky používateľa)"

#. Translators: When viewing a user's profile (e.g. https://wikipedialibrary.wmflabs.org/users/ when logged in), this labels the recent edit count of the user across all Wikimedia projects. Don't remove the *
#: TWLight/users/templates/users/editor_detail_data.html:215
msgid "Recent global edit count *"
msgstr "Nedávny globálny počet úprav *"

